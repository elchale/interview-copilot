# AI Provider API Keys (set via control menu or here)
# These are optional here — the control menu is the preferred way to set keys.
# Keys set here override the control menu.

# STT Provider (whisper_api / deepgram / local)
STT_PROVIDER=whisper_api
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# LLM Provider (anthropic / openai / gemini)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
