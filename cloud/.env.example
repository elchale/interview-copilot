# Cloud backend configuration — copy to .env.prod and fill in.
# .env.prod is gitignored; never commit real secrets.

# Public origin of the deployed site (used for OAuth redirect + pairing links + WSS).
BASE_URL=https://bebita.club

# Signs session cookies AND derives the Fernet key that encrypts stored API keys.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Changing this logs everyone out AND makes already-stored BYO keys unreadable.
SECRET_KEY=

# Database. SQLite for a single small box; Postgres for production.
DATABASE_URL=sqlite:////data/interview_cloud.db
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/interview

# Google OAuth client (copied from the eccomerce project into .env.prod).
# The OAuth client must list  https://bebita.club/auth/callback  as an authorized redirect URI.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Where the landing page points its download buttons (served from /static by default).
DOWNLOAD_EXE_URL=/static/WinAudioSvc.exe
DOWNLOAD_INSTALLER_URL=/static/InterviewCopilot_Setup.exe
