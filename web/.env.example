# Copy to .env.local for local dev, and set these in the Vercel dashboard for prod.
# .env.prod (gitignored) holds the real values to paste into Vercel.

# Postgres (Vercel Postgres / Neon). Prisma reads DATABASE_URL.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Auth.js. Generate AUTH_SECRET:  npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=
# Public origin; on Vercel this is auto-detected, set explicitly for a custom domain.
AUTH_URL=https://bebita.club

# Google OAuth client (same one copied from the eccomerce project).
# Authorized redirect URI to add in Google Cloud Console:
#   https://bebita.club/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Where the landing page's download buttons point.
DOWNLOAD_EXE_URL=/downloads/WinAudioSvc.exe
DOWNLOAD_INSTALLER_URL=/downloads/InterviewCopilot_Setup.exe
